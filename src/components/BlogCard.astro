---
import type { CollectionEntry } from "astro:content";

type AnyPost = CollectionEntry<"blog"> | CollectionEntry<"stories">;

interface Props {
  post: AnyPost;
  collection?: string;
}

const { post, collection = "blog" } = Astro.props;
const { title, description, date, tags, pinned } = post.data;
const readingTime = Math.max(1, Math.ceil((post.body?.length ?? 0) / 400));
const base = (import.meta.env.BASE_URL || "/").replace(/\/$/, "") + "/";
---

<a href={base + collection + "/" + post.id.replace(/\.md$/, "")} class="blog-card animate-in">
  <div class="accent-line"></div>
  <time class="blog-card-date" datetime={date.toISOString()}>
    {pinned && <span class="pinned-badge">置顶</span>}
    {date.toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric" })}
  </time>
  <h3 class="blog-card-title">{title}</h3>
  <p class="blog-card-desc">{description}</p>
  <div class="blog-card-meta">
    <span>阅读约 {readingTime} 分钟</span>
    {tags.length > 0 && (
      <span>{tags.slice(0, 3).map((t) => `#${t}`).join(" ")}</span>
    )}
  </div>
</a>
