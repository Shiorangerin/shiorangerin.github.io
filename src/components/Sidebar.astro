---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const base = (import.meta.env.BASE_URL || "/").replace(/\/$/, "") + "/";

const navItems = [
  { href: base, label: "首页", icon: "house" },
  { href: base + "blog", label: "默想", icon: "pen" },
  { href: base + "stories", label: "故事", icon: "book" },
  { href: base + "projects", label: "项目", icon: "code" },
  { href: base + "bible", label: "读经", icon: "cross" },
  { href: base + "about", label: "关于", icon: "person" },
  { href: base + "links", label: "其他", icon: "link" },
];

function isActive(href: string, path: string) {
  if (href === base || href === base.slice(0, -1)) return path === "/" || path === "";
  return path.startsWith(href.replace(base, "/"));
}

const iconMap: Record<string, string> = {
  house: `<svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5L12 4l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-9.5z"/><path d="M9 21V13h6v8"/></svg>`,
  pen: `<svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
  book: `<svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
  cross: `<svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20"/></svg>`,
  person: `<svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>`,
  link: `<svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>`,
  code: `<svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
};
---

<aside class="sidebar">
  <a href={base} class="sidebar-profile" style="text-decoration: none; color: inherit;">
    <img src={base + "avatar.jpg"} alt="Avatar" class="sidebar-avatar" />
    <div>
      <div class="sidebar-name">Rinchez</div>
      <div class="sidebar-handle">@orangerin</div>
    </div>
  </a>

  <div class="sidebar-section-label">导航</div>

  <nav class="sidebar-nav">
    {navItems.map((item) => (
      <a
        href={item.href}
        class={`sidebar-link ${isActive(item.href, currentPath) ? "active" : ""}`}
        aria-current={isActive(item.href, currentPath) ? "page" : undefined}
      >
        <Fragment set:html={iconMap[item.icon] ?? ""} />
        <span>{item.label}</span>
      </a>
    ))}
  </nav>

  <div class="sidebar-section-label">社交媒体</div>
  <div class="sidebar-socials">
    <a href="https://x.com/elonmusk" target="_blank" rel="noopener noreferrer" class="sidebar-social" title="Twitter / X">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </a>
    <a href="https://im.qq.com" target="_blank" rel="noopener noreferrer" class="sidebar-social" title="QQ">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21.295 15.329c-.298-.446-.496-.942-.595-1.487-.099-.546-.05-1.092.05-1.637.248-1.388.545-2.726.248-4.114-.347-1.537-1.29-2.727-2.628-3.57C17.527 3.825 16.19 3.23 14.706 3.08c-.844-.05-1.688 0-2.58.1-1.736.198-3.373.893-4.86 1.935-.545.397-1.041.893-1.389 1.438-.694 1.091-.893 2.38-.843 3.67.05 1.338.297 2.627.595 3.916.1.297.149.645.05.943-.1.297-.248.545-.446.793-.645.744-1.29 1.488-1.835 2.28-.248.348-.446.745-.496 1.19-.05.397.05.794.248 1.14.397.695 1.091 1.042 1.886 1.042.744 0 1.537-.248 2.18-.496.893-.347 1.736-.794 2.628-1.09.347-.1.694-.2.992-.1.545.1 1.091.347 1.587.546.793.297 1.488.694 2.28.893.298.1.546.15.794.15.496 0 .942-.2 1.24-.546.445-.496.546-1.19.397-1.786-.1-.397-.298-.744-.496-1.09z"/></svg>
    </a>
    <a href="https://weibo.com/u/1784473157" target="_blank" rel="noopener noreferrer" class="sidebar-social" title="微博">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M10.098 19.876c-5.144-.1-9.033-3.34-8.685-7.25.348-3.91 4.387-7.022 9.53-6.924 5.144.1 9.033 3.34 8.685 7.25-.348 3.91-4.387 7.022-9.53 6.924zm4.606-5.28c-.303-.447-.958-.525-1.615-.218-.728.342-1.247.514-1.882.488-.693-.028-1.105-.258-1.105-.547 0-.287.326-.495.968-.664.583-.153 1.267-.375 1.9-.649 2.02-.874 2.646-1.974 2.233-2.97-.274-.66-.985-.958-1.85-.97-1.686-.023-3.61.754-4.714 1.924-1.103 1.17-1.521 2.482-1.092 3.452.436.985 1.51 1.463 2.755 1.349 1.985-.182 4.034-1.042 5.402-2.195z"/></svg>
    </a>
    <a href="https://facebook.com/zuck" target="_blank" rel="noopener noreferrer" class="sidebar-social" title="Facebook">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
    </a>
    <a href="https://github.com/torvalds" target="_blank" rel="noopener noreferrer" class="sidebar-social" title="GitHub">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
    </a>
  </div>

  <div class="sidebar-footer">
    <span class="theme-label">明暗</span>
    <button
      id="theme-toggle"
      class="theme-toggle"
      aria-label="切换明暗模式"
      title="切换明暗模式"
    >
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/>
        <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
      </svg>
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </div>
</aside>

<script>
  const toggle = document.getElementById("theme-toggle");
  toggle?.addEventListener("click", () => {
    const isDark = document.documentElement.hasAttribute("data-theme");
    if (isDark) {
      document.documentElement.removeAttribute("data-theme");
      localStorage.setItem("theme", "light");
    } else {
      document.documentElement.setAttribute("data-theme", "dark");
      localStorage.setItem("theme", "dark");
    }
  });
</script>