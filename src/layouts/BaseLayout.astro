---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  articleDate?: string;
  articleUpdated?: string;
  articleTags?: string[];
  noindex?: boolean;
  showProgress?: boolean;
}

const {
  title,
  description,
  ogImage,
  ogType = "website",
  articleDate,
  articleUpdated,
  articleTags = [],
  noindex,
  showProgress = false,
} = Astro.props;
const siteTitle = "Shiorangerin";
const siteUrl = "https://shiorangerin.github.io";
const fullTitle = title === "首页" ? siteTitle : `${title} — ${siteTitle}`;
const desc = description ?? "Shiorangerin 的个人站点 —— 信仰、技术与生活。";
const currentPath = Astro.url.pathname;
const base = (import.meta.env.BASE_URL || "/").replace(/\/$/, "") + "/";
const defaultOgImage = siteUrl + base.replace(/\/$/, "") + "/avatar.jpg";

function isActive(href: string, path: string) {
  if (href === base || href === base.slice(0, -1)) return path === "/" || path === "";
  return path.startsWith(href.replace(base, "/"));
}

const mobileNav = [
  { href: base, label: "首页", icon: "house" },
  { href: base + "blog", label: "默想", icon: "pen" },
  { href: base + "stories", label: "故事", icon: "book" },
  { href: base + "projects", label: "项目", icon: "code" },
  { href: base + "bible", label: "读经", icon: "cross" },
  { href: base + "about", label: "关于", icon: "person" },
  { href: base + "links", label: "其他", icon: "link" },
];

const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage ? (ogImage.startsWith("http") ? ogImage : siteUrl + (ogImage.startsWith("/") ? ogImage : "/" + ogImage)) : defaultOgImage;

const jsonLd: Record<string, unknown>[] = [];
if (articleDate && ogType === "article") {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: title,
    description: desc,
    datePublished: articleDate,
    ...(articleUpdated ? { dateModified: articleUpdated } : {}),
    author: { "@type": "Person", "name": "Shiorangerin", "url": siteUrl },
    url: canonical,
  });
  const collection = currentPath.startsWith("/blog") ? "默想" : currentPath.startsWith("/stories") ? "故事" : "";
  if (collection) {
    jsonLd.push({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "首页", item: siteUrl },
        { "@type": "ListItem", position: 2, name: collection, item: siteUrl + "/" + (currentPath.startsWith("/blog") ? "blog" : "stories") },
        { "@type": "ListItem", position: 3, name: title },
      ],
    });
  }
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <link rel="canonical" href={canonical} />
    <meta name="description" content={desc} />
    {noindex && <meta name="robots" content="noindex" />}

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content="Shiorangerin" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@shiorangerin" />
    <meta name="twitter:creator" content="@shiorangerin" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImageUrl} />

    {articleDate && <meta property="article:published_time" content={articleDate} />}
    {articleUpdated && <meta property="article:modified_time" content={articleUpdated} />}
    {articleTags.map((tag) => <meta property="article:tag" content={tag} />)}

    <meta name="theme-color" content="#f5f0e8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1612" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" href={base + "favicon.png"} />
    <link rel="apple-touch-icon" href={base + "apple-touch-icon.png"} />
    <link rel="alternate" type="application/rss+xml" title="Shiorangerin 默想" href={base + "rss.xml"} />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    {jsonLd.map((ld) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(ld)} />
    ))}
  </head>
  <body style={`background-image: url(${base}wallpaper.webp)`}>
    <a href="#main-content" class="skip-link">跳到主内容</a>
    {showProgress && <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>}
    <script>
      (() => {
        const root = document.documentElement;
        const stored = localStorage.getItem("theme");
        const systemDark = window.matchMedia("(prefers-color-scheme: dark)");
        const apply = (dark: boolean) => {
          if (dark) root.setAttribute("data-theme", "dark");
          else root.removeAttribute("data-theme");
        };

        if (stored === "dark" || stored === "light") {
          apply(stored === "dark");
        } else {
          apply(systemDark.matches);
        }

        systemDark.addEventListener("change", (e) => {
          if (localStorage.getItem("theme")) return;
          apply(e.matches);
        });
      })();
    </script>

    <div class="page-wrapper">
      <Sidebar currentPath={currentPath} />
      <main class="main-content" id="main-content">
        <div class="content-container">
          <slot />
        </div>
      </main>
    </div>

    <nav class="mobile-nav" aria-label="移动导航">
      {mobileNav.map((item) => (
        <a
          href={item.href}
          class={`mobile-nav-item ${isActive(item.href, currentPath) ? "active" : ""}`}
          aria-label={item.label}
          aria-current={isActive(item.href, currentPath) ? "page" : undefined}
        >
          {item.icon === "house" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 10.5L12 4l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-9.5z"/><path d="M9 21V13h6v8"/>
            </svg>
          )}
          {item.icon === "pen" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
          )}
          {item.icon === "book" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
          )}
          {item.icon === "cross" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v20M2 12h20"/>
            </svg>
          )}
          {item.icon === "person" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/>
            </svg>
          )}
          {item.icon === "link" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          )}
          {item.icon === "code" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
          )}
          <span>{item.label}</span>
        </a>
      ))}
      <button class="mobile-theme-toggle" id="mobile-theme-toggle" aria-label="切换明暗模式">
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </nav>
  </body>
</html>

<script>
  document.getElementById("mobile-theme-toggle")?.addEventListener("click", () => {
    const isDark = document.documentElement.hasAttribute("data-theme");
    if (isDark) {
      document.documentElement.removeAttribute("data-theme");
      localStorage.setItem("theme", "light");
    } else {
      document.documentElement.setAttribute("data-theme", "dark");
      localStorage.setItem("theme", "dark");
    }
  });
</script>

{showProgress && (
  <script>
    const bar = document.getElementById("reading-progress");
    const article = document.querySelector<HTMLElement>(".blog-post");
    if (bar && article) {
      let raf = 0;
      const update = () => {
        raf = 0;
        const rect = article.getBoundingClientRect();
        const articleTop = rect.top + window.scrollY;
        const articleHeight = article.offsetHeight;
        const viewportH = window.innerHeight;
        const scrolled = window.scrollY - articleTop;
        const trackable = Math.max(1, articleHeight - viewportH);
        const ratio = Math.max(0, Math.min(1, scrolled / trackable));
        bar.style.width = (ratio * 100).toFixed(2) + "%";
        if (ratio > 0.02 || window.scrollY > articleTop) {
          bar.classList.remove("reading-progress--idle");
        } else {
          bar.classList.add("reading-progress--idle");
        }
      };
      const onScroll = () => {
        if (!raf) raf = requestAnimationFrame(update);
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll);
      update();
    }
  </script>
)}
