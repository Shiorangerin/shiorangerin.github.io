---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404" noindex>
  <article class="glass-card animate-in" style="text-align: center; padding: 3rem 2rem;">
    <h1 style="font-size: 4rem; margin: 0 0 0.5rem; background: linear-gradient(135deg, var(--accent), #8b4513); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">404</h1>
    <p style="font-size: 1.2rem; color: var(--text-secondary); margin-bottom: 1.5rem;">这页不存在于地上</p>
    <a href="/" class="glass-card" style="display: inline-block; padding: 0.75rem 1.5rem; text-decoration: none; color: var(--text-primary); font-weight: 500;">回到首页</a>
  </article>
</BaseLayout>
