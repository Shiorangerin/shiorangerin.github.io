---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="关于" description="关于 Shiorangerin">
  <section class="animate-in">
    <div class="glass-card">
      <h1 style="margin-bottom: 1.5rem;">关于</h1>

      <div class="about-section">
        <h3>我是谁</h3>
        <p>
          一个其实对于 Coding 一窍不通，正在高强度与 LLM 斗智斗勇的普通人。
        </p>
      </div>

      <div class="about-section">
        <h3>关于本站</h3>
        <p>
          本站尚在建设中，但已可以初步使用。
        </p>
        <p style="color: var(--text-tertiary); font-size: 0.88rem;">
          基于 <a href="https://astro.build">Astro</a> 构建。
        </p>
      </div>

      <div>
        <h3 style="margin-bottom: 0.5rem;">找到我</h3>
        <p style="color: var(--text-secondary);">
          宇宙很大，生活更大，我们总会再次见面的。
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
