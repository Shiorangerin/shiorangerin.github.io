---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogCard from "../components/BlogCard.astro";
import { getCollection } from "astro:content";

const recentPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);
const base = (import.meta.env.BASE_URL || "/").replace(/\/$/, "") + "/";
---

<BaseLayout title="首页" description="Shiorangerin 的个人站点 —— 信仰、技术与生活的默想。">
  <section class="animate-in">
    <div class="glass-card">
      <p class="badge">愿主赐福</p>
      <h1>
        凡劳苦担重担的人，可以到我这里来
      </h1>
      <br>
      <p>
        你们要将一切的忧虑卸给神，因为他顾念你们。
      </p>
      <p>
        你们要尝尝主恩的滋味，便知道他是美善；投靠他的人有福了！
      </p>
      <div>
        <a href={base + "blog"}>
          阅读默想
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
        <a href={base + "about"}>
          关于
        </a>
      </div>
    </div>
  </section>

   <section>
     {
      recentPosts.length === 0 ? (
        <div class="glass-card empty-state">
          <p>暂无默想，稍后再来看看。</p>
        </div>
      ) : (
        recentPosts.map((post, i) => (
          <div class={`animate-in stagger-${Math.min(i + 1, 4)}`}>
            <BlogCard post={post} />
          </div>
        ))
      )
    }
    {recentPosts.length > 0 && (
      <a href={base + "blog"} class="view-all-card animate-in stagger-5">
        <div class="accent-line"></div>
        <span class="view-all-card-label">
          浏览全部默想
          <span class="view-all-card-count">{recentPosts.length} 篇近期</span>
        </span>
        <span class="view-all-card-action">
          全部默想
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
          </svg>
        </span>
      </a>
    )}
  </section>
</BaseLayout>
